{
  "name": "brain-desktop",
  "version": "1.1.0",
  "description": "Brain Agent Desktop — Electron shell for the web UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "author": "Alexander Klinsky",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.brain-agent.desktop",
    "productName": "Brain Agent",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icons/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "icons/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "icons/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "alexioklini",
      "repo": "cctest"
    }
  }
}
