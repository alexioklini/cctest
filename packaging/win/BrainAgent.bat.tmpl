@echo off
setlocal
set "SCRIPT_DIR=%~dp0"
if "%BRAIN_DATA_DIR%"=="" set "BRAIN_DATA_DIR=%LOCALAPPDATA%\BrainAgent"

if not exist "%BRAIN_DATA_DIR%" mkdir "%BRAIN_DATA_DIR%"

rem ---- Seed/refresh app files on version change (config.json is NEVER
rem ---- overwritten — install.ps1 patched it with the Mac-mini IP etc.)
set "VFILE=%BRAIN_DATA_DIR%\.brain-bundle-version"
set "CUR_VER="
if exist "%VFILE%" set /p CUR_VER=<"%VFILE%"
set /p NEW_VER=<"%SCRIPT_DIR%app\.version"
if not "%CUR_VER%"=="%NEW_VER%" (
  echo Aktualisiere %BRAIN_DATA_DIR% aus dem Bundle...
  robocopy "%SCRIPT_DIR%app" "%BRAIN_DATA_DIR%" /E /NFL /NDL /NJH /NJS /XF config.json searxng_settings.yml >nul
  if not exist "%BRAIN_DATA_DIR%\config.json" copy /Y "%SCRIPT_DIR%app\config.json" "%BRAIN_DATA_DIR%\config.json" >nul
  if not exist "%BRAIN_DATA_DIR%\searxng_settings.yml" copy /Y "%SCRIPT_DIR%app\searxng_settings.yml" "%BRAIN_DATA_DIR%\searxng_settings.yml" >nul
  copy /Y "%SCRIPT_DIR%app\.version" "%VFILE%" >nul
)

rem ---- Optionale Overrides (Minimal-Profil): install.ps1 schreibt
rem ---- %BRAIN_DATA_DIR%\brain-env.bat (z. B. MEMPALACE_QDRANT_URL auf den
rem ---- Mac mini + BRAIN_QDRANT_LOCAL=0) — Defaults unten nur, wenn nicht gesetzt.
if exist "%BRAIN_DATA_DIR%\brain-env.bat" call "%BRAIN_DATA_DIR%\brain-env.bat"

rem ---- MemPalace environment (Qdrant local; embedding device/url kommen aus
rem ---- config.json -> mempalace.* und werden von server.py in die Env
rem ---- geseedet: remote = oMLX auf dem Mac mini, Fallback CPU-ONNX aus dem
rem ---- Bundle-hf-cache -> offline-faehig)
set "MEMPALACE_BACKEND=qdrant"
if not defined MEMPALACE_QDRANT_URL set "MEMPALACE_QDRANT_URL=http://127.0.0.1:6333"
set "MEMPALACE_QDRANT_QUANTIZATION=int8"
set "MEMPALACE_EMBEDDING_MODEL=embeddinggemma"
set "HF_HOME=%SCRIPT_DIR%hf-cache"
set "HF_HUB_OFFLINE=1"
set "PYTHONDONTWRITEBYTECODE=1"
set "PYTHONUNBUFFERED=1"

rem ---- Qdrant (remote im Minimal-Profil; skip start if already answering)
if "%BRAIN_QDRANT_LOCAL%"=="0" goto qdrant_ok
curl -s -o nul --max-time 2 http://127.0.0.1:6333/readyz
if not errorlevel 1 goto qdrant_ok
set "QDRANT__STORAGE__STORAGE_PATH=%BRAIN_DATA_DIR%\qdrant-storage"
set "QDRANT__STORAGE__SNAPSHOTS_PATH=%BRAIN_DATA_DIR%\qdrant-snapshots"
set "QDRANT__TELEMETRY_DISABLED=true"
set "QDRANT__SERVICE__HTTP_PORT=6333"
echo Starte Qdrant...
start "BrainAgent Qdrant" /MIN "%SCRIPT_DIR%qdrant\qdrant.exe"
set /a QTRIES=0
:wait_qdrant
set /a QTRIES+=1
if %QTRIES% GTR 60 (
  echo FEHLER: Qdrant antwortet nicht auf http://127.0.0.1:6333/readyz
  pause
  exit /b 1
)
timeout /t 1 /nobreak >nul
curl -s -o nul --max-time 2 http://127.0.0.1:6333/readyz
if errorlevel 1 goto wait_qdrant
:qdrant_ok

echo Starte Brain-Agent-Server auf Port 8420...
cd /d "%BRAIN_DATA_DIR%"
"%SCRIPT_DIR%python\python.exe" "%BRAIN_DATA_DIR%\server.py" %*
endlocal
