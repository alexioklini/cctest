# Ignore .claude/ contents, but TRACK the committed project settings + safety
# hooks (the deny hook that blocks SIGKILL to the brain-agent server — SIGKILL
# corrupts MemPalace HNSW). Note: git can't re-include a file under an excluded
# DIR, so we ignore the dir's contents (.claude/*) rather than the dir itself,
# then negate the files we want, un-ignoring the hooks/ subdir on the way down.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/block-sigkill-brain.sh
agents/*/artifacts/
agents/*/chats-indexed/
agents/*/user_profiles/
agents/*/scheduled_attachments/
agents/*/projects/
agents/.trash/
agents/test-*/

# Per-agent AES-GCM key for transparent-anonymisation mapping encryption.
# Bootstrapped on first use by pseudonymizer.py; mode 0600; refusing to commit
# preserves cross-machine isolation + means a leaked repo can't decrypt
# historical mappings persisted in chats.db.
agents/*/pseudonym.key

