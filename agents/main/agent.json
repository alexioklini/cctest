{
  "description": "General-purpose main agent",
  "model": "CLIProxyAPI/mistral-medium-3.5",
  "avatar": "captain",
  "display_name": "Main",
  "memory_summary": {
    "enabled": true,
    "paused": false,
    "frequency": "every 24h",
    "start_time": "03:00",
    "model": "mistral-vibe-cli-latest",
    "model_fallback": "devstral-small-latest"
  },
  "hooks": {
    "enabled": true,
    "timeout": 5000,
    "scripts": [
      {
        "name": "block-dangerous",
        "type": "pre",
        "tools": [
          "execute_command"
        ],
        "script": "hooks/block-dangerous.sh",
        "enabled": true
      }
    ]
  },
  "autodream": {
    "model": "devstral-small-latest"
  },
  "relationship_discovery": {
    "model": "mistralai/mistral-small-2603",
    "model_fallback": "mistral-vibe-cli-latest"
  },
  "token_config": {
    "tool_groups": [
      "core",
      "memory",
      "context",
      "web",
      "email",
      "documents",
      "delegation",
      "code_graph",
      "git",
      "scheduler",
      "skills",
      "nodes"
    ],
    "include_tools_guide": true,
    "include_memory_summary": true,
    "memory_summary_cap": 2000,
    "compact_threshold": null,
    "scheduled_task_tools": true,
    "deferred_tool_groups": [
      "email",
      "documents",
      "code_graph",
      "scheduler",
      "delegation"
    ]
  },
  "paused": false,
  "agent_sdk": {
    "enabled": true
  },
  "auto_memory": {
    "model": "mistral-vibe-cli-latest",
    "model_fallback": "devstral-small-latest"
  },
  "next_prompt_suggestions": {
    "enabled": true,
    "model": "CLIProxyAPI/mistral-medium-3.5",
    "max_words": 15
  }
}