#!/usr/bin/env bash
#
# Backstop for the brain-agent-guide skill (Brainy's knowledge base).
#
# The skill at agents/main/skills/brain-agent-guide/ must stay in lockstep
# with the code. This hook flags a push where:
#   (a) feature code changed but the skill did not, OR
#   (b) the skill's recorded brain_agent_version trails brain.py's VERSION,
# so the docs Brainy reads don't silently drift.
#
# It is a REMINDER, not a judge — it can't tell a docs-irrelevant refactor
# from a real feature. If the change genuinely needs no skill update, push
# again with SKILL_DOC_OK=1 (or git push --no-verify).
#
# Installed via:  git config core.hooksPath .githooks
# (run once; see CLAUDE.md "Keeping the brain-agent-guide skill current").

set -euo pipefail

SKILL_DIR="agents/main/skills/brain-agent-guide"

# Paths whose changes plausibly affect what Brainy should document:
# endpoints, tools, schemas, UI, version/changelog. Tune as the repo moves.
WATCH_RE='^(brain\.py|server\.py|handlers/|engine/tool_schemas\.py|engine/tools/|server_lib/db\.py|web/index\.html|web/js/)'

if [[ "${SKILL_DOC_OK:-}" == "1" ]]; then
  exit 0
fi

# ── Backstop: scrubbed config.example.json in sync with config.json ──
# The pre-commit hook regenerates + stages it on every commit, but commits can
# be made with --no-verify; this catches a stale mirror before it reaches the
# remote. Only runs when this machine has a config.json to compare against
# (a fresh clone / CI has none → nothing to check). Non-mutating (--check).
if [[ -f scripts/scrub_config.py && -f config.json ]]; then
  if ! python3 scripts/scrub_config.py --check; then
    cat >&2 <<'EOF'

──────────────────────────────────────────────────────────────────────
  config.example.json is STALE vs config.json.

  Regenerate + commit it:
    python3 scripts/scrub_config.py && git add config.example.json && git commit --amend --no-edit
  (or just re-commit normally — the pre-commit hook stages it for you).
──────────────────────────────────────────────────────────────────────
EOF
    exit 1
  fi
fi

# stdin: <local ref> <local sha> <remote ref> <remote sha> per pushed ref.
needs_check=0
drifted=0
changelog_drifted=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions (all-zero local sha).
  if [[ "$local_sha" =~ ^0+$ ]]; then
    continue
  fi

  # Determine the commit range being pushed. For a new branch the remote
  # sha is all-zero; fall back to "everything not already on origin".
  if [[ "$remote_sha" =~ ^0+$ ]]; then
    range="$local_sha"
    extra='--not --remotes=origin'
  else
    range="${remote_sha}..${local_sha}"
    extra=''
  fi

  changed=$(git diff --name-only "$range" $extra 2>/dev/null || true)
  [[ -z "$changed" ]] && continue

  if echo "$changed" | grep -Eq "$WATCH_RE"; then
    needs_check=1
    if ! echo "$changed" | grep -q "^${SKILL_DIR}/"; then
      drifted=1
    fi
  fi

  # Curated end-user version history: if this range bumps brain.py's VERSION
  # line but never touches engine/changelog_curated.py, the user-facing history
  # likely drifted. (Diff the VERSION line specifically — a brain.py touch that
  # leaves VERSION alone is not a release.)
  if echo "$changed" | grep -q '^brain\.py$' \
     && ! echo "$changed" | grep -q '^engine/changelog_curated\.py$'; then
    if git diff "$range" $extra -- brain.py 2>/dev/null | grep -Eq '^\+VERSION = "'; then
      changelog_drifted=1
    fi
  fi
done

# ── Version-drift check: skill's brain_agent_version vs brain.py VERSION ──
# Independent of the code-touch check above — a skill left at an old
# brain_agent_version is stale even if this particular push touches no code.
version_drift=0
code_ver=$(sed -n 's/^VERSION = "\([^"]*\)".*/\1/p' brain.py 2>/dev/null | head -1)
skill_ver=$(sed -n 's/^[[:space:]]*brain_agent_version:[[:space:]]*\(.*\)/\1/p' \
            "${SKILL_DIR}/SKILL.md" 2>/dev/null | head -1 | tr -d '"'"'"' \r')
if [[ -n "$code_ver" && -n "$skill_ver" && "$code_ver" != "$skill_ver" ]]; then
  version_drift=1
fi

if [[ "$version_drift" == "1" ]]; then
  cat >&2 <<EOF

──────────────────────────────────────────────────────────────────────
  brain-agent-guide skill version check

  The skill records  brain_agent_version: ${skill_ver}
  but brain.py is at  VERSION = ${code_ver}

  The skill is the knowledge base Brainy reads. If the changes since
  ${skill_ver} added or altered anything a user could ask about, update the
  matching reference file AND bump brain_agent_version (+ skill_version)
  in ${SKILL_DIR}/SKILL.md to ${code_ver}.

  If nothing user-facing changed, just bump brain_agent_version to ${code_ver}
  in the same push, or re-push:

    SKILL_DOC_OK=1 git push        # or:  git push --no-verify
──────────────────────────────────────────────────────────────────────

EOF
  exit 1
fi

if [[ "$needs_check" == "1" && "$drifted" == "1" ]]; then
  cat >&2 <<EOF

──────────────────────────────────────────────────────────────────────
  brain-agent-guide skill check

  This push changes feature code (endpoints / tools / schemas / UI /
  version) but does NOT touch ${SKILL_DIR}/.

  That skill is the knowledge base Brainy reads to answer users. If this
  change adds or alters something a user could ask about, update the
  matching reference file in the same push:

    SKILL.md · 01-api.md · 02-tools.md · 03-storage.md
    04-recipes.md · 05-internals.md · 06-user-manual.md

  If no doc update is needed (internal refactor, test-only, etc.), re-push:

    SKILL_DOC_OK=1 git push        # or:  git push --no-verify
──────────────────────────────────────────────────────────────────────

EOF
  exit 1
fi

if [[ "$changelog_drifted" == "1" && "${CHANGELOG_OK:-}" != "1" ]]; then
  cat >&2 <<EOF

──────────────────────────────────────────────────────────────────────
  curated version-history check

  This push bumps brain.py VERSION but does NOT touch
  engine/changelog_curated.py.

  That file is the end-user version history shown when a user clicks the
  version in the left sidebar. If this release adds or changes anything an
  end user or admin can SEE, add a curated entry at the TOP (benefit-oriented
  German — see CLAUDE.md "Keeping the curated version history current").

  If the release is purely internal (perf, invisible fix, refactor), re-push:

    CHANGELOG_OK=1 git push        # or:  git push --no-verify
──────────────────────────────────────────────────────────────────────

EOF
  exit 1
fi

exit 0
